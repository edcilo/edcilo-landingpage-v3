---
interface Props {
	dialectLabel: string;
	dialectOptions: { label: string; value: string }[];
	inputLabel: string;
	inputPlaceholder: string;
	outputLabel: string;
	formatLabel: string;
	copyLabel: string;
	copiedLabel: string;
	errorMessage: string;
}

const {
	dialectLabel,
	dialectOptions,
	inputLabel,
	inputPlaceholder,
	outputLabel,
	formatLabel,
	copyLabel,
	copiedLabel,
	errorMessage,
} = Astro.props;

const textareaClass =
	'w-full resize-y rounded-lg border border-border bg-muted/50 px-4 py-3 font-mono text-sm text-foreground placeholder:text-muted-foreground transition-colors duration-200 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20';
const labelClass = 'mb-2 block font-mono text-sm font-medium text-foreground';
---

<div
	data-sqlformatter-tool
	data-copied-label={copiedLabel}
	class="mx-auto max-w-4xl space-y-6"
>
	<!-- Dialect selector -->
	<div>
		<label for="sqlformatter-dialect" class={labelClass}>{dialectLabel}</label>
		<select
			id="sqlformatter-dialect"
			data-sqlformatter-dialect
			class="w-full rounded-lg border border-border bg-muted/50 px-4 py-3 font-mono text-sm text-foreground transition-colors duration-200 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
		>
			{
				dialectOptions.map((opt) => (
					<option value={opt.value}>{opt.label}</option>
				))
			}
		</select>
	</div>

	<!-- Input / Output panels -->
	<div class="grid grid-cols-1 gap-4 md:grid-cols-2">
		<div>
			<label for="sqlformatter-input" class={labelClass}>{inputLabel}</label>
			<textarea
				id="sqlformatter-input"
				data-sqlformatter-input
				rows="12"
				wrap="off"
				spellcheck="false"
				placeholder={inputPlaceholder}
				class={textareaClass}></textarea>
		</div>
		<div>
			<label id="sqlformatter-output-label" class={labelClass}
				>{outputLabel}</label
			>
			<pre
				tabindex="0"
				aria-labelledby="sqlformatter-output-label"
				class="w-full min-h-[18rem] overflow-x-auto overflow-y-auto rounded-lg border border-border bg-muted/50 px-4 py-3 font-mono text-sm text-foreground transition-colors duration-200 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"><code class="hljs language-sql" data-sqlformatter-output /></pre>
		</div>
	</div>

	<!-- Actions -->
	<div class="flex flex-wrap items-center justify-center gap-3">
		<button
			type="button"
			data-sqlformatter-format
			class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 font-mono text-sm font-medium text-primary-foreground transition-colors duration-200 hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:ring-offset-2 focus:ring-offset-background"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				fill="none"
				viewBox="0 0 24 24"
				stroke-width="1.5"
				stroke="currentColor"
				class="size-5"
				aria-hidden="true"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M17.25 6.75 22.5 12l-5.25 5.25M6.75 17.25 1.5 12l5.25-5.25"></path>
			</svg>
			{formatLabel}
		</button>

		<button
			type="button"
			data-sqlformatter-copy
			disabled
			aria-label={copyLabel}
			class="inline-flex items-center gap-2 rounded-lg border border-border bg-muted px-6 py-3 font-mono text-sm font-medium text-foreground transition-colors duration-200 hover:border-primary/40 hover:bg-primary/10 hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:ring-offset-2 focus:ring-offset-background disabled:cursor-not-allowed disabled:opacity-50 disabled:hover:border-border disabled:hover:bg-muted disabled:hover:text-foreground"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				fill="none"
				viewBox="0 0 24 24"
				stroke-width="1.5"
				stroke="currentColor"
				class="size-5"
				aria-hidden="true"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184"
				></path>
			</svg>
			<span data-sqlformatter-copy-label>{copyLabel}</span>
		</button>
	</div>

	<!-- Error message -->
	<p
		role="alert"
		aria-live="polite"
		data-sqlformatter-error
		class="hidden text-center font-mono text-sm text-red-500 dark:text-red-400"
	>
		{errorMessage}
	</p>
</div>

<script>
	import { format, type SqlLanguage } from 'sql-formatter';
	import hljs from 'highlight.js/lib/core';
	import sql from 'highlight.js/lib/languages/sql';

	hljs.registerLanguage('sql', sql);

	function setupSqlFormatterTool(): void {
		const containers = document.querySelectorAll<HTMLElement>(
			'[data-sqlformatter-tool]',
		);
		containers.forEach((container) => {
			if (container.hasAttribute('data-sqlformatter-initialized')) return;
			container.setAttribute('data-sqlformatter-initialized', '');

			const dialectEl = container.querySelector<HTMLSelectElement>(
				'[data-sqlformatter-dialect]',
			);
			const inputEl = container.querySelector<HTMLTextAreaElement>(
				'[data-sqlformatter-input]',
			);
			const outputEl = container.querySelector<HTMLElement>(
				'[data-sqlformatter-output]',
			);
			const formatBtn = container.querySelector<HTMLButtonElement>(
				'[data-sqlformatter-format]',
			);
			const copyBtn = container.querySelector<HTMLButtonElement>(
				'[data-sqlformatter-copy]',
			);
			const copyLabelEl = container.querySelector<HTMLElement>(
				'[data-sqlformatter-copy-label]',
			);
			const errorEl = container.querySelector<HTMLElement>(
				'[data-sqlformatter-error]',
			);

			if (
				!dialectEl ||
				!inputEl ||
				!outputEl ||
				!formatBtn ||
				!copyBtn ||
				!errorEl
			) {
				return;
			}

			let plainOutput = '';
			const copyText = copyLabelEl?.textContent ?? '';
			const copiedText = container.getAttribute('data-copied-label') ?? '';
			let copyTimeout: ReturnType<typeof setTimeout> | undefined;

			function hideError(): void {
				errorEl!.classList.add('hidden');
			}

			formatBtn.addEventListener('click', () => {
				hideError();
				const rawSql = inputEl!.value;

				if (!rawSql.trim()) {
					plainOutput = '';
					outputEl!.textContent = '';
					copyBtn!.disabled = true;
					return;
				}

				try {
					const result = format(rawSql, {
						language: dialectEl!.value as SqlLanguage,
						keywordCase: 'upper',
						tabWidth: 2,
					});
					plainOutput = result;
					// SECURITY: hljs.highlight() escapes the source text before
					// wrapping tokens in <span>. The text comes from sql-formatter's
					// processed output, never raw user HTML.
					outputEl!.innerHTML = hljs.highlight(result, {
						language: 'sql',
					}).value;
					copyBtn!.disabled = false;
				} catch {
					errorEl!.classList.remove('hidden');
					plainOutput = '';
					outputEl!.textContent = '';
					copyBtn!.disabled = true;
				}
			});

			copyBtn.addEventListener('click', async () => {
				if (!plainOutput) return;
				try {
					await navigator.clipboard.writeText(plainOutput);
					if (copyLabelEl) {
						copyLabelEl.textContent = copiedText;
						if (copyTimeout) clearTimeout(copyTimeout);
						copyTimeout = setTimeout(() => {
							copyLabelEl.textContent = copyText;
						}, 2000);
					}
				} catch {
					/* Clipboard unavailable: silently ignore. */
				}
			});
		});
	}

	setupSqlFormatterTool();
	document.addEventListener('astro:page-load', setupSqlFormatterTool);
</script>

<!--
  Highlight.js syntax highlighting styles for the SQL output panel.
  Uses <style is:global> because the highlighted markup is injected
  dynamically via innerHTML at runtime, so Astro's scoped styles
  (which rely on data-astro-cid-* attributes) would not apply.
  All rules are scoped to [data-sqlformatter-output] to prevent
  leaking into other parts of the page.
-->
<style is:global>
	/* --- Light mode (default) --- */
	[data-sqlformatter-output] .hljs-keyword {
		color: #7c3aed;
	}
	[data-sqlformatter-output] .hljs-string {
		color: #059669;
	}
	[data-sqlformatter-output] .hljs-number {
		color: #d97706;
	}
	[data-sqlformatter-output] .hljs-built_in,
	[data-sqlformatter-output] .hljs-title.function_ {
		color: #0284c7;
	}
	[data-sqlformatter-output] .hljs-comment {
		color: #737373;
		font-style: italic;
	}
	[data-sqlformatter-output] .hljs-operator {
		color: #dc2626;
	}
	[data-sqlformatter-output] .hljs-punctuation {
		color: var(--color-muted-foreground);
	}

	/* --- Dark mode overrides --- */
	.dark [data-sqlformatter-output] .hljs-keyword {
		color: #a78bfa;
	}
	.dark [data-sqlformatter-output] .hljs-string {
		color: #34d399;
	}
	.dark [data-sqlformatter-output] .hljs-number {
		color: #fbbf24;
	}
	.dark [data-sqlformatter-output] .hljs-built_in,
	.dark [data-sqlformatter-output] .hljs-title.function_ {
		color: #38bdf8;
	}
	.dark [data-sqlformatter-output] .hljs-comment {
		color: #a3a3a3;
		font-style: italic;
	}
	.dark [data-sqlformatter-output] .hljs-operator {
		color: #f87171;
	}
	.dark [data-sqlformatter-output] .hljs-punctuation {
		color: var(--color-muted-foreground);
	}
</style>
