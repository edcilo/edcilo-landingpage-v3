{
	"headers": [
		{
			"source": "/_astro/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(.*).{avif,webp,png,jpg,jpeg,gif,svg,ico}",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=86400, stale-while-revalidate=604800"
				}
			]
		},
		{
			"source": "/(.*).{js,css}",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(.*).{woff,woff2}",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		}
	]
}
