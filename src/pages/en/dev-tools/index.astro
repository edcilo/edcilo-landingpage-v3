---
import Layout from '../../../layouts/Layout.astro';
import TypewriterHeading from '../../../components/TypewriterHeading.astro';
import ToolCategoryCard from '../../../components/ToolCategoryCard.astro';
import { TOOL_CATEGORIES } from '../../../data/toolCategories';
import { DEFAULT_LOCALE } from '../../../i18n/config';
import { useTranslations } from '../../../i18n/utils';

const locale = Astro.currentLocale ?? DEFAULT_LOCALE;
const t = useTranslations(locale);
---

<Layout
	title={`${t('devtools.title')} — edcilo`}
	description={t('devtools.subtitle')}
>
	<section class="py-16 sm:py-24" aria-labelledby="devtools-heading">
		<TypewriterHeading
			id="devtools-heading"
			title={t('devtools.title')}
			subtitle={t('devtools.subtitle')}
		/>

		<div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3 md:gap-6">
			{
				TOOL_CATEGORIES.map((category) => (
					<ToolCategoryCard
						title={t(category.titleKey)}
						icon={category.icon}
						slug={category.slug}
						tools={category.tools}
						locale={locale}
					/>
				))
			}
		</div>
	</section>
</Layout>
