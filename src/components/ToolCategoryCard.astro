---
import type { Tool } from '../data/toolCategories';
import { getLocalizedPath } from '../i18n/utils';

interface Props {
	title: string;
	icon: string;
	slug: string;
	tools: Tool[];
	locale: string;
	class?: string;
}

const { title, icon, slug, tools, locale, class: className } = Astro.props;

const ICON_HOVER_COLORS: Record<string, string> = {
	encoders: 'group-hover:text-amber-500',
	converters: 'group-hover:text-cyan-500',
	formatters: 'group-hover:text-violet-500',
	generators: 'group-hover:text-emerald-500',
	textutils: 'group-hover:text-rose-500',
};

const iconHoverColor = ICON_HOVER_COLORS[slug] ?? 'group-hover:text-foreground';
---

<article
	class:list={[
		'group relative h-full overflow-hidden rounded-xl border border-border p-6 transition-all duration-300 ease-out hover:border-muted-foreground/60 hover:bg-muted/50',
		className,
	]}
>
	<!-- Decorative glow -->
	<div
		class="pointer-events-none absolute -top-24 -right-24 h-48 w-48 rounded-full bg-[radial-gradient(circle,var(--color-muted-foreground)_0%,transparent_70%)] opacity-[0.04] transition-all duration-500 ease-out group-hover:h-64 group-hover:w-64 group-hover:opacity-[0.08]"
		aria-hidden="true"
	>
	</div>

	<!-- Header -->
	<div class="mb-4 flex items-center gap-2">
		<svg
			xmlns="http://www.w3.org/2000/svg"
			fill="none"
			viewBox="0 0 24 24"
			stroke-width="1.5"
			stroke="currentColor"
			class:list={[
				'size-5 text-muted-foreground transition-colors duration-300',
				iconHoverColor,
			]}
			aria-hidden="true"
		>
			<path stroke-linecap="round" stroke-linejoin="round" d={icon}></path>
		</svg>
		<h3
			class="font-mono text-xs font-medium uppercase tracking-wider text-muted-foreground transition-all duration-300 group-hover:font-bold group-hover:text-foreground"
		>
			{title}
		</h3>
	</div>

	<!-- Separator -->
	<hr class="mb-4 border-dashed border-border transition-colors duration-300" />

	<!-- Tools list -->
	<div class="flex flex-wrap gap-2">
		{
			tools.map((tool) =>
				tool.href ? (
					<a
						href={getLocalizedPath(tool.href, locale)}
						class="inline-flex items-center gap-1.5 rounded-md border border-border bg-muted px-3 py-1.5 font-mono text-sm text-foreground transition-colors duration-300 hover:border-primary/40 hover:bg-primary/10 hover:text-primary"
					>
						{tool.name}
						<svg
							xmlns="http://www.w3.org/2000/svg"
							fill="none"
							viewBox="0 0 24 24"
							stroke-width="2"
							stroke="currentColor"
							class="size-3"
							aria-hidden="true"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
							/>
						</svg>
					</a>
				) : (
					<span class="inline-flex items-center gap-1.5 rounded-md border border-border bg-muted px-3 py-1.5 font-mono text-sm text-foreground transition-colors duration-300 hover:bg-accent hover:text-accent-foreground">
						{tool.name}
					</span>
				),
			)
		}
	</div>
</article>
