		'morbi',
		'senectus',
		'netus',
		'malesuada',
		'fames',
	];

	function setupLoremTool(): void {
		const containers =
			document.querySelectorAll<HTMLElement>('[data-lorem-tool]');
		containers.forEach((container) => {
			if (container.hasAttribute('data-lorem-initialized')) return;
			container.setAttribute('data-lorem-initialized', '');

			const wordsEl =
				container.querySelector<HTMLInputElement>('[data-lorem-words]');
			const paragraphsEl = container.querySelector<HTMLInputElement>(
				'[data-lorem-paragraphs]',
			);
			const startEl =
				container.querySelector<HTMLInputElement>('[data-lorem-start]');
			const htmlEl =
				container.querySelector<HTMLInputElement>('[data-lorem-html]');
			const generateBtn = container.querySelector<HTMLButtonElement>(
				'[data-lorem-generate]',
			);
			const copyBtn =
				container.querySelector<HTMLButtonElement>('[data-lorem-copy]');
			const copyLabelEl = container.querySelector<HTMLElement>(
				'[data-lorem-copy-label]',
			);
			const outputEl = container.querySelector<HTMLTextAreaElement>(
				'[data-lorem-output]',
			);
			const counterEl = container.querySelector<HTMLElement>(
				'[data-lorem-counter]',
			);

			if (
				!wordsEl ||
				!paragraphsEl ||
				!startEl ||
				!htmlEl ||
				!generateBtn ||
				!copyBtn ||
				!outputEl ||
				!counterEl
			) {
				return;
			}

			const copyText = copyLabelEl?.textContent ?? '';
			const copiedText = container.getAttribute('data-copied-label') ?? '';
			const wordsCounterLabel =
				container.getAttribute('data-words-label') ?? 'Words';
			const charsCounterLabel =
				container.getAttribute('data-chars-label') ?? 'Characters';
			let copyTimeout: ReturnType<typeof setTimeout> | undefined;

			const INCIPIT = [
				'lorem',
				'ipsum',
				'dolor',
				'sit',
				'amet',
				'consectetur',
				'adipiscing',
				'elit',
			];

			function clampNumber(
				el: HTMLInputElement,
				min: number,
				max: number,
				fallback: number,
			): number {
				const raw = Number(el.value);
				if (!Number.isFinite(raw)) return fallback;
				return Math.min(max, Math.max(min, Math.floor(raw)));
			}

			function randomWord(): string {
				return LOREM_WORDS[Math.floor(Math.random() * LOREM_WORDS.length)];
			}

			function capitalize(word: string): string {
				return word.charAt(0).toUpperCase() + word.slice(1);
			}

			// Build a paragraph of exactly `count` words, grouped into punctuated sentences.
			function buildParagraph(count: number, useIncipit: boolean): string {
				const words: string[] = [];
				if (useIncipit) {
					for (let i = 0; i < INCIPIT.length && i < count; i++) {
						words.push(INCIPIT[i]);
					}
				}
				while (words.length < count) {
					words.push(randomWord());
				}

				const sentences: string[] = [];
				let i = 0;
				while (i < count) {
					const remaining = count - i;
					// Sentence length 8-15 words, but absorb a tiny remainder.
					let len = 8 + Math.floor(Math.random() * 8);
					if (remaining - len < 4) len = remaining;
					len = Math.min(len, remaining);
					const slice = words.slice(i, i + len);
					i += len;

					// Optional comma in the middle of longer sentences.
					if (slice.length >= 8) {
						const commaPos = 3 + Math.floor(Math.random() * (slice.length - 5));
						slice[commaPos] = slice[commaPos] + ',';
					}
					slice[0] = capitalize(slice[0]);
					sentences.push(slice.join(' ') + '.');
				}
				return sentences.join(' ');
			}

			function generate(): void {
				const wordsPer = clampNumber(wordsEl!, 5, 200, 50);
				wordsEl!.value = wordsPer.toString();
				const paragraphCount = clampNumber(paragraphsEl!, 1, 50, 3);
				paragraphsEl!.value = paragraphCount.toString();
				const useHtml = htmlEl!.checked;

				const paragraphs: string[] = [];
				for (let p = 0; p < paragraphCount; p++) {
					const text = buildParagraph(wordsPer, startEl!.checked && p === 0);
					paragraphs.push(useHtml ? `<p>${text}</p>` : text);
				}
				const output = paragraphs.join(useHtml ? '\n' : '\n\n');
				outputEl!.value = output;

				const plain = output.replace(/<[^>]+>/g, ' ');
				const wordCount = plain.split(/\s+/).filter(Boolean).length;
				counterEl!.textContent = `${wordsCounterLabel}: ${wordCount} · ${charsCounterLabel}: ${output.length}`;
				copyBtn!.disabled = output.length === 0;
			}

			generateBtn.addEventListener('click', generate);
			[wordsEl, paragraphsEl, startEl, htmlEl].forEach((el) => {
				el.addEventListener('change', generate);
			});

			copyBtn.addEventListener('click', async () => {
				const text = outputEl!.value;
				if (!text) return;
				try {
					await navigator.clipboard.writeText(text);
					if (copyLabelEl) {
						copyLabelEl.textContent = copiedText;
						if (copyTimeout) clearTimeout(copyTimeout);
						copyTimeout = setTimeout(() => {
							copyLabelEl.textContent = copyText;
						}, 2000);
					}
				} catch {
					/* Clipboard unavailable: silently ignore. */
				}
			});

			generate();
		});
	}

	setupLoremTool();
	document.addEventListener('astro:page-load', setupLoremTool);
</script>
