---
import Layout from '../../../layouts/Layout.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import SqlFormatterTool from '../../../components/SqlFormatterTool.astro';
import { DEFAULT_LOCALE } from '../../../i18n/config';
import { useTranslations, getLocalizedPath } from '../../../i18n/utils';

const locale = Astro.currentLocale ?? DEFAULT_LOCALE;
const t = useTranslations(locale);

const dialectOptions = [
	{ label: t('devtools.sqlformatter.dialect.sql'), value: 'sql' },
	{ label: t('devtools.sqlformatter.dialect.mysql'), value: 'mysql' },
	{
		label: t('devtools.sqlformatter.dialect.postgresql'),
		value: 'postgresql',
	},
	{ label: t('devtools.sqlformatter.dialect.mariadb'), value: 'mariadb' },
	{ label: t('devtools.sqlformatter.dialect.sqlite'), value: 'sqlite' },
	{
		label: t('devtools.sqlformatter.dialect.transactsql'),
		value: 'transactsql',
	},
	{ label: t('devtools.sqlformatter.dialect.bigquery'), value: 'bigquery' },
	{ label: t('devtools.sqlformatter.dialect.snowflake'), value: 'snowflake' },
];
---

<Layout
	title={`${t('devtools.sqlformatter.title')} — edcilo`}
	description={t('devtools.sqlformatter.subtitle')}
>
	<section class="py-16 sm:py-24" aria-labelledby="sqlformatter-heading">
		<a
			href={getLocalizedPath('/dev-tools/', locale)}
			class="mb-8 inline-flex items-center gap-1 font-mono text-sm text-muted-foreground transition-colors hover:text-foreground"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				fill="none"
				viewBox="0 0 24 24"
				stroke-width="1.5"
				stroke="currentColor"
				class="size-4"
				aria-hidden="true"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"></path>
			</svg>
			{t('devtools.backToDevTools')}
		</a>

		<SectionHeading
			id="sqlformatter-heading"
			title={t('devtools.sqlformatter.title')}
			subtitle={t('devtools.sqlformatter.subtitle')}
		/>

		<div class="mx-auto mb-10 max-w-4xl space-y-2">
			<p class="text-sm leading-relaxed text-muted-foreground">
				{t('devtools.sqlformatter.description')}
			</p>
			<p class="font-mono text-sm text-muted-foreground">
				{t('devtools.sqlformatter.example')}
			</p>
		</div>

		<SqlFormatterTool
			dialectLabel={t('devtools.sqlformatter.dialect.label')}
			dialectOptions={dialectOptions}
			inputLabel={t('devtools.sqlformatter.input.label')}
			inputPlaceholder={t('devtools.sqlformatter.input.placeholder')}
			outputLabel={t('devtools.sqlformatter.output.label')}
			formatLabel={t('devtools.sqlformatter.format')}
			copyLabel={t('devtools.sqlformatter.copy')}
			copiedLabel={t('devtools.sqlformatter.copied')}
			errorMessage={t('devtools.sqlformatter.error.invalid')}
		/>
	</section>
</Layout>
