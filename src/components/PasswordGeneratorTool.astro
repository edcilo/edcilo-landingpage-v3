---
interface Props {
	typeRandomLabel: string;
	typeWordsLabel: string;
	lengthLabel: string;
	vowelsLabel: string;
	consonantsLabel: string;
	numbersLabel: string;
	specialLabel: string;
	uppercaseLabel: string;
	excludeAmbiguousLabel: string;
	guaranteeLabel: string;
	wordsCountLabel: string;
	languageLabel: string;
	languageEs: string;
	languageEn: string;
	separatorLabel: string;
	sepDash: string;
	sepUnderscore: string;
	sepDot: string;
	sepSpace: string;
	sepNone: string;
	addNumberLabel: string;
	addSpecialLabel: string;
	generateLabel: string;
	regenerateLabel: string;
	copyLabel: string;
	copiedLabel: string;
	outputLabel: string;
	outputPlaceholder: string;
	strengthLabel: string;
	strengthWeak: string;
	strengthFair: string;
	strengthGood: string;
	strengthStrong: string;
	strengthVeryStrong: string;
	bitsLabel: string;
	errorNoClass: string;
	defaultLanguage?: string;
}

const {
	typeRandomLabel,
	typeWordsLabel,
	lengthLabel,
	vowelsLabel,
	consonantsLabel,
	numbersLabel,
	specialLabel,
	uppercaseLabel,
	excludeAmbiguousLabel,
	guaranteeLabel,
	wordsCountLabel,
	languageLabel,
	languageEs,
	languageEn,
	separatorLabel,
	sepDash,
	sepUnderscore,
	sepDot,
	sepSpace,
	sepNone,
	addNumberLabel,
	addSpecialLabel,
	generateLabel,
	regenerateLabel,
	copyLabel,
	copiedLabel,
	outputLabel,
	outputPlaceholder,
	strengthLabel,
	strengthWeak,
	strengthFair,
	strengthGood,
	strengthStrong,
	strengthVeryStrong,
	bitsLabel,
	errorNoClass,
	defaultLanguage = 'es',
} = Astro.props;

const controlClass =
	'w-full rounded-lg border border-border bg-muted/50 px-4 py-2.5 font-mono text-sm text-foreground transition-colors duration-200 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20';
const labelClass = 'mb-2 block font-mono text-sm font-medium text-foreground';
const checkClass =
	'inline-flex items-center gap-2 font-mono text-sm text-foreground';
const checkInputClass =
	'size-4 rounded border-border text-primary focus:ring-2 focus:ring-primary/20';
const typeBtnClass =
	'rounded-lg px-4 py-2.5 font-mono text-sm font-medium transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-primary/20';
---

<div
	data-pw-tool
	data-copied-label={copiedLabel}
	data-bits-label={bitsLabel}
	data-sl-weak={strengthWeak}
	data-sl-fair={strengthFair}
	data-sl-good={strengthGood}
	data-sl-strong={strengthStrong}
	data-sl-verystrong={strengthVeryStrong}
	class="mx-auto max-w-3xl space-y-6"
>
	<!-- Type switch -->
	<div
		class="grid grid-cols-2 gap-2 rounded-xl border border-border bg-muted/30 p-1"
	>
		<button
			type="button"
			data-pw-type="random"
			aria-pressed="true"
			class={`${typeBtnClass} bg-primary text-primary-foreground`}
		>
			{typeRandomLabel}
		</button>
		<button
			type="button"
			data-pw-type="words"
			aria-pressed="false"
			class={`${typeBtnClass} text-muted-foreground hover:text-foreground`}
		>
			{typeWordsLabel}
		</button>
	</div>

	<!-- Random panel -->
	<div data-pw-panel="random" class="space-y-5">
		<div>
			<label for="pw-length" class={labelClass}>{lengthLabel}</label>
			<input
				id="pw-length"
				data-pw-length
				type="number"
				inputmode="numeric"
				min="4"
				max="128"
				step="1"
				value="16"
				class={`${controlClass} tabular-nums`}
			/>
		</div>

		<div class="flex flex-wrap gap-x-6 gap-y-3">
			<label class={checkClass}>
				<input
					type="checkbox"
					data-pw-class="vowels"
					checked
					class={checkInputClass}
				/>
				{vowelsLabel}
			</label>
			<label class={checkClass}>
				<input
					type="checkbox"
					data-pw-class="consonants"
					checked
					class={checkInputClass}
				/>
				{consonantsLabel}
			</label>
			<label class={checkClass}>
				<input
					type="checkbox"
					data-pw-class="numbers"
					checked
					class={checkInputClass}
				/>
				{numbersLabel}
			</label>
			<label class={checkClass}>
				<input
					type="checkbox"
					data-pw-class="special"
					checked
					class={checkInputClass}
				/>
				{specialLabel}
			</label>
		</div>

		<div class="flex flex-wrap gap-x-6 gap-y-3">
			<label class={checkClass}>
				<input
					type="checkbox"
					data-pw-uppercase
					checked
					class={checkInputClass}
				/>
				{uppercaseLabel}
			</label>
			<label class={checkClass}>
				<input
					type="checkbox"
					data-pw-exclude-ambiguous
					class={checkInputClass}
				/>
				{excludeAmbiguousLabel}
			</label>
			<label class={checkClass}>
				<input type="checkbox" data-pw-guarantee class={checkInputClass} />
				{guaranteeLabel}
			</label>
		</div>
	</div>

	<!-- Words panel -->
	<div data-pw-panel="words" class="hidden space-y-5">
		<div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
			<div>
				<label for="pw-words-count" class={labelClass}>{wordsCountLabel}</label>
				<input
					id="pw-words-count"
					data-pw-words-count
					type="number"
					inputmode="numeric"
					min="2"
					max="12"
					step="1"
					value="4"
					class={`${controlClass} tabular-nums`}
				/>
			</div>
			<div>
				<label for="pw-language" class={labelClass}>{languageLabel}</label>
				<select id="pw-language" data-pw-language class={controlClass}>
					<option value="es" selected={defaultLanguage === 'es'}
						>{languageEs}</option
					>
					<option value="en" selected={defaultLanguage === 'en'}
						>{languageEn}</option
					>
				</select>
			</div>
			<div>
				<label for="pw-separator" class={labelClass}>{separatorLabel}</label>
				<select id="pw-separator" data-pw-separator class={controlClass}>
					<option value="dash">{sepDash}</option>
					<option value="underscore">{sepUnderscore}</option>
					<option value="dot">{sepDot}</option>
					<option value="space">{sepSpace}</option>
					<option value="none">{sepNone}</option>
				</select>
			</div>
		</div>

		<div class="flex flex-wrap gap-x-6 gap-y-3">
			<label class={checkClass}>
				<input type="checkbox" data-pw-add-number class={checkInputClass} />
				{addNumberLabel}
			</label>
			<label class={checkClass}>
				<input type="checkbox" data-pw-add-special class={checkInputClass} />
				{addSpecialLabel}
			</label>
		</div>
	</div>

	<!-- Error -->
	<p
		role="alert"
		data-pw-error
		class="hidden font-mono text-sm text-red-500 dark:text-red-400"
	>
		{errorNoClass}
	</p>

	<!-- Output -->
	<div>
		<label for="pw-output" class={labelClass}>{outputLabel}</label>
		<input
			id="pw-output"
			data-pw-output
			type="text"
			readonly
			placeholder={outputPlaceholder}
			class="w-full rounded-lg border border-border bg-muted/50 px-4 py-3 font-mono text-base text-foreground placeholder:text-muted-foreground transition-colors duration-200 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
		/>
	</div>

	<!-- Strength -->
	<div>
		<div class="mb-2 flex items-center justify-between font-mono text-sm">
			<span class="text-muted-foreground">{strengthLabel}</span>
			<span data-pw-strength-text class="text-muted-foreground tabular-nums"
			></span>
		</div>
		<div
			class="h-2 w-full overflow-hidden rounded-full bg-muted"
			role="progressbar"
			aria-live="polite"
		>
			<div
				data-pw-strength-bar
				class="h-full w-0 rounded-full bg-muted transition-all duration-300"
			>
			</div>
		</div>
	</div>

	<!-- Actions -->
	<div class="flex flex-wrap items-center justify-center gap-3">
		<button
			type="button"
			data-pw-generate
			class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-2.5 font-mono text-sm font-medium text-primary-foreground transition-colors duration-200 hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:ring-offset-2 focus:ring-offset-background"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				fill="none"
				viewBox="0 0 24 24"
				stroke-width="1.5"
				stroke="currentColor"
				class="size-5"
				aria-hidden="true"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.847-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.847.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z"
				></path>
			</svg>
			{generateLabel}
		</button>

		<button
			type="button"
			data-pw-regenerate
			class="inline-flex items-center gap-2 rounded-lg border border-border bg-muted px-6 py-2.5 font-mono text-sm font-medium text-foreground transition-colors duration-200 hover:border-primary/40 hover:bg-primary/10 hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:ring-offset-2 focus:ring-offset-background"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				fill="none"
				viewBox="0 0 24 24"
				stroke-width="1.5"
				stroke="currentColor"
				class="size-5"
				aria-hidden="true"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"
				></path>
			</svg>
			{regenerateLabel}
		</button>

		<button
			type="button"
			data-pw-copy
			disabled
			class="inline-flex items-center gap-2 rounded-lg border border-border bg-muted px-6 py-2.5 font-mono text-sm font-medium text-foreground transition-colors duration-200 hover:border-primary/40 hover:bg-primary/10 hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:ring-offset-2 focus:ring-offset-background disabled:cursor-not-allowed disabled:opacity-50 disabled:hover:border-border disabled:hover:bg-muted disabled:hover:text-foreground"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				fill="none"
				viewBox="0 0 24 24"
				stroke-width="1.5"
				stroke="currentColor"
				class="size-5"
				aria-hidden="true"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184"
				></path>
			</svg>
			<span data-pw-copy-label>{copyLabel}</span>
		</button>
	</div>
</div>

<script>
	import { PASSWORD_WORDS } from '../data/passwordWords';

	const VOWELS = 'aeiou';
	const CONSONANTS = 'bcdfghjklmnpqrstvwxyz';
	const NUMBERS = '0123456789';
	const SPECIAL = '!@#$%^&*()-_=+[]{};:,.?';
	const AMBIGUOUS = new Set('Oo0Il1|S5B8'.split(''));
	const SEPARATORS: Record<string, string> = {
		dash: '-',
		underscore: '_',
		dot: '.',
		space: ' ',
		none: '',
	};

	function randomInt(max: number): number {
		if (max <= 0) return 0;
		const limit = Math.floor(0xffffffff / max) * max;
		const buf = new Uint32Array(1);
		let x = 0;
		do {
			crypto.getRandomValues(buf);
			x = buf[0];
		} while (x >= limit);
		return x % max;
	}

	function pick(chars: string): string {
		return chars.charAt(randomInt(chars.length));
	}

	function shuffle<T>(arr: T[]): T[] {
		for (let i = arr.length - 1; i > 0; i--) {
			const j = randomInt(i + 1);
			[arr[i], arr[j]] = [arr[j], arr[i]];
		}
		return arr;
	}

	function setupPasswordTool(): void {
		const containers = document.querySelectorAll<HTMLElement>('[data-pw-tool]');
		containers.forEach((container) => {
			if (container.hasAttribute('data-pw-initialized')) return;
			container.setAttribute('data-pw-initialized', '');

			const typeBtns =
				container.querySelectorAll<HTMLButtonElement>('[data-pw-type]');
			const panels = container.querySelectorAll<HTMLElement>('[data-pw-panel]');
			const lengthEl =
				container.querySelector<HTMLInputElement>('[data-pw-length]');
			const classEls =
				container.querySelectorAll<HTMLInputElement>('[data-pw-class]');
			const uppercaseEl = container.querySelector<HTMLInputElement>(
				'[data-pw-uppercase]',
			);
			const excludeEl = container.querySelector<HTMLInputElement>(
				'[data-pw-exclude-ambiguous]',
			);
			const guaranteeEl = container.querySelector<HTMLInputElement>(
				'[data-pw-guarantee]',
			);
			const wordsCountEl = container.querySelector<HTMLInputElement>(
				'[data-pw-words-count]',
			);
			const languageEl =
				container.querySelector<HTMLSelectElement>('[data-pw-language]');
			const separatorEl = container.querySelector<HTMLSelectElement>(
				'[data-pw-separator]',
			);
			const addNumberEl = container.querySelector<HTMLInputElement>(
				'[data-pw-add-number]',
			);
			const addSpecialEl = container.querySelector<HTMLInputElement>(
				'[data-pw-add-special]',
			);
			const errorEl = container.querySelector<HTMLElement>('[data-pw-error]');
			const outputEl =
				container.querySelector<HTMLInputElement>('[data-pw-output]');
			const strengthBar = container.querySelector<HTMLElement>(
				'[data-pw-strength-bar]',
			);
			const strengthText = container.querySelector<HTMLElement>(
				'[data-pw-strength-text]',
			);
			const generateBtn =
				container.querySelector<HTMLButtonElement>('[data-pw-generate]');
			const regenerateBtn = container.querySelector<HTMLButtonElement>(
				'[data-pw-regenerate]',
			);
			const copyBtn =
				container.querySelector<HTMLButtonElement>('[data-pw-copy]');
			const copyLabelEl = container.querySelector<HTMLElement>(
				'[data-pw-copy-label]',
			);

			if (
				!lengthEl ||
				!uppercaseEl ||
				!excludeEl ||
				!guaranteeEl ||
				!wordsCountEl ||
				!languageEl ||
				!separatorEl ||
				!addNumberEl ||
				!addSpecialEl ||
				!errorEl ||
				!outputEl ||
				!strengthBar ||
				!strengthText ||
				!generateBtn ||
				!regenerateBtn ||
				!copyBtn
			) {
				return;
			}

			const copyText = copyLabelEl?.textContent ?? '';
			const copiedText = container.getAttribute('data-copied-label') ?? '';
			const bitsLabel = container.getAttribute('data-bits-label') ?? 'bits';
			const levels = [
				{
					label: container.getAttribute('data-sl-weak') ?? '',
					color: 'bg-red-500',
					width: 20,
				},
				{
					label: container.getAttribute('data-sl-fair') ?? '',
					color: 'bg-orange-500',
					width: 40,
				},
				{
					label: container.getAttribute('data-sl-good') ?? '',
					color: 'bg-yellow-500',
					width: 60,
				},
				{
					label: container.getAttribute('data-sl-strong') ?? '',
					color: 'bg-green-500',
					width: 80,
				},
				{
					label: container.getAttribute('data-sl-verystrong') ?? '',
					color: 'bg-emerald-500',
					width: 100,
				},
			];
			let copyTimeout: ReturnType<typeof setTimeout> | undefined;
			let currentType = 'random';

			function clampNumber(
				el: HTMLInputElement,
				min: number,
				max: number,
				fallback: number,
			): number {
				const raw = Number(el.value);
				if (!Number.isFinite(raw)) return fallback;
				return Math.min(max, Math.max(min, Math.floor(raw)));
			}

			function filterAmbiguous(chars: string): string {
				return chars
					.split('')
					.filter((c) => !AMBIGUOUS.has(c))
					.join('');
			}

			function buildRandom(): { password: string; entropy: number } | null {
				const useUpper = uppercaseEl!.checked;
				const exclude = excludeEl!.checked;
				const pools: string[] = [];
				classEls.forEach((el) => {
					if (!el.checked) return;
					const key = el.getAttribute('data-pw-class');
					let chars = '';
					if (key === 'vowels')
						chars = useUpper ? VOWELS + VOWELS.toUpperCase() : VOWELS;
					else if (key === 'consonants')
						chars = useUpper
							? CONSONANTS + CONSONANTS.toUpperCase()
							: CONSONANTS;
					else if (key === 'numbers') chars = NUMBERS;
					else if (key === 'special') chars = SPECIAL;
					if (exclude) chars = filterAmbiguous(chars);
					if (chars) pools.push(chars);
				});

				if (pools.length === 0) return null;

				const length = clampNumber(lengthEl!, 4, 128, 16);
				lengthEl!.value = length.toString();
				const combined = pools.join('');
				const chars: string[] = [];

				if (guaranteeEl!.checked) {
					pools.forEach((pool) => {
						if (chars.length < length) chars.push(pick(pool));
					});
				}
				while (chars.length < length) {
					chars.push(pick(combined));
				}
				shuffle(chars);
				const password = chars.slice(0, length).join('');
				const entropy = length * Math.log2(combined.length);
				return { password, entropy };
			}

			function buildWords(): { password: string; entropy: number } {
				const count = clampNumber(wordsCountEl!, 2, 12, 4);
				wordsCountEl!.value = count.toString();
				const lang = languageEl!.value === 'en' ? 'en' : 'es';
				const list = PASSWORD_WORDS[lang];
				const sep = SEPARATORS[separatorEl!.value] ?? '-';

				const words: string[] = [];
				for (let i = 0; i < count; i++) {
					words.push(list[randomInt(list.length)]);
				}
				let password = words.join(sep);
				let entropy = count * Math.log2(list.length);

				if (addNumberEl!.checked) {
					password += pick(NUMBERS);
					entropy += Math.log2(NUMBERS.length);
				}
				if (addSpecialEl!.checked) {
					password += pick(SPECIAL);
					entropy += Math.log2(SPECIAL.length);
				}
				return { password, entropy };
			}

			function renderStrength(entropy: number): void {
				let index = 0;
				if (entropy >= 100) index = 4;
				else if (entropy >= 80) index = 3;
				else if (entropy >= 60) index = 2;
				else if (entropy >= 40) index = 1;
				else index = 0;
				const level = levels[index];
				strengthBar!.className = `h-full rounded-full transition-all duration-300 ${level.color}`;
				strengthBar!.style.width = `${level.width}%`;
				strengthText!.textContent = `${level.label} · ${Math.round(entropy)} ${bitsLabel}`;
			}

			function clearStrength(): void {
				strengthBar!.className =
					'h-full w-0 rounded-full bg-muted transition-all duration-300';
				strengthBar!.style.width = '0%';
				strengthText!.textContent = '';
			}

			function updateCopyState(): void {
				copyBtn!.disabled = outputEl!.value.length === 0;
			}

			function generate(): void {
				errorEl!.classList.add('hidden');
				const result = currentType === 'words' ? buildWords() : buildRandom();
				if (!result) {
					outputEl!.value = '';
					clearStrength();
					updateCopyState();
					errorEl!.classList.remove('hidden');
					return;
				}
				outputEl!.value = result.password;
				renderStrength(result.entropy);
				updateCopyState();
			}

			function setType(type: string): void {
				currentType = type;
				typeBtns.forEach((btn) => {
					const isActive = btn.getAttribute('data-pw-type') === type;
					btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
					btn.classList.toggle('bg-primary', isActive);
					btn.classList.toggle('text-primary-foreground', isActive);
					btn.classList.toggle('text-muted-foreground', !isActive);
					btn.classList.toggle('hover:text-foreground', !isActive);
				});
				panels.forEach((panel) => {
					panel.classList.toggle(
						'hidden',
						panel.getAttribute('data-pw-panel') !== type,
					);
				});
				generate();
			}

			typeBtns.forEach((btn) => {
				btn.addEventListener('click', () =>
					setType(btn.getAttribute('data-pw-type') ?? 'random'),
				);
			});

			container
				.querySelectorAll<HTMLElement>(
					'[data-pw-panel] input, [data-pw-panel] select',
				)
				.forEach((el) => {
					el.addEventListener('change', generate);
				});

			generateBtn.addEventListener('click', generate);
			regenerateBtn.addEventListener('click', generate);

			copyBtn.addEventListener('click', async () => {
				const text = outputEl!.value;
				if (!text) return;
				try {
					await navigator.clipboard.writeText(text);
					if (copyLabelEl) {
						copyLabelEl.textContent = copiedText;
						if (copyTimeout) clearTimeout(copyTimeout);
						copyTimeout = setTimeout(() => {
							copyLabelEl.textContent = copyText;
						}, 2000);
					}
				} catch {
					/* Clipboard unavailable: silently ignore. */
				}
			});

			generate();
		});
	}

	setupPasswordTool();
	document.addEventListener('astro:page-load', setupPasswordTool);
</script>
