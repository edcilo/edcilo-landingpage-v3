---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import TypewriterHeading from '../../components/TypewriterHeading.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import BlogSearchInput from '../../components/BlogSearchInput.astro';
import BlogPagination from '../../components/BlogPagination.astro';
import { DEFAULT_LOCALE } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';
import { getReadingTime } from '../../utils/readingTime';

export const getStaticPaths = (async ({ paginate }) => {
	const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
		(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
	);

	const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();

	return paginate(posts, {
		pageSize: 15,
		props: { allTags },
	});
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const { allTags } = Astro.props;
const locale = Astro.currentLocale ?? DEFAULT_LOCALE;
const t = useTranslations(locale);
---

<Layout title={`${t('blog.title')} — edcilo`} description={t('blog.subtitle')}>
	<section class="py-16 sm:py-24" aria-labelledby="blog-heading">
		<TypewriterHeading
			id="blog-heading"
			title={t('blog.title')}
			subtitle={t('blog.subtitle')}
		/>

		<BlogSearchInput
			placeholder={t('blog.search.placeholder')}
			label={t('blog.search.label')}
			noResultsMessage={t('blog.search.noResults')}
			readingTimeLabel={t('blog.readingTime')}
			tags={allTags}
			filterLabel={t('blog.filter.label')}
			allLabel={t('blog.filter.all')}
			filterNoResultsMessage={t('blog.filter.noResults')}
		/>

		{
			page.data.length > 0 ? (
				<div
					data-blog-grid
					class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3 md:gap-6"
				>
					{page.data.map((post) => (
						<BlogPostCard
							title={post.data.title}
							description={post.data.description}
							date={post.data.date}
							tags={post.data.tags}
							slug={post.id}
							readingTime={getReadingTime(post.body ?? '')}
						/>
					))}
				</div>
			) : (
				<p class="text-center font-mono text-muted-foreground">
					{t('blog.empty')}
				</p>
			)
		}

		<BlogPagination
			currentPage={page.currentPage}
			lastPage={page.lastPage}
			url={page.url}
		/>
	</section>
</Layout>
