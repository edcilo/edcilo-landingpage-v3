---
import SkillPill from './SkillPill.astro';
import { DEFAULT_LOCALE } from '../i18n/config';
import {
	useTranslations,
	getLocalizedPath,
	getDateLocale,
} from '../i18n/utils';

interface Props {
	title: string;
	description: string;
	date: Date;
	tags: string[];
	slug: string;
	readingTime: number;
	blur?: boolean;
}

const {
	title,
	description,
	date,
	tags,
	slug,
	readingTime,
	blur = false,
} = Astro.props;
const locale = Astro.currentLocale ?? DEFAULT_LOCALE;
const t = useTranslations(locale);
const dateLocale = getDateLocale(locale);
---

<article
	data-tags={tags.join(',')}
	data-title={title.toLowerCase()}
	data-description={description.toLowerCase()}
	class:list={[
		'group relative overflow-hidden rounded-xl border border-border p-6 transition-[background-color,border-color] duration-300 ease-out hover:border-muted-foreground/60',
		blur
			? 'bg-background/20 backdrop-blur-[3px] hover:bg-background/40'
			: 'bg-background hover:bg-muted/50',
	]}
>
	<!-- Decorative glow -->
	<div
		class="pointer-events-none absolute -top-24 -right-24 h-48 w-48 origin-center rounded-full bg-[radial-gradient(circle,var(--color-muted-foreground)_0%,transparent_70%)] opacity-[0.04] transition-[transform,opacity] duration-500 ease-out group-hover:scale-[1.33] group-hover:opacity-[0.08]"
		aria-hidden="true"
	>
	</div>

	<a
		href={getLocalizedPath(`/blog/${slug}`, locale)}
		class="block rounded-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background"
		aria-label={`Read post: ${title}`}
	>
		<!-- Date -->
		<time
			datetime={date.toISOString()}
			class="font-mono text-xs text-muted-foreground"
		>
			{
				date.toLocaleDateString(dateLocale, {
					year: 'numeric',
					month: 'short',
					day: 'numeric',
					hour: '2-digit',
					minute: '2-digit',
				})
			}
		</time>
		<span class="ml-2 font-mono text-xs text-muted-foreground">
			·
			{t('blog.readingTime').replace('{min}', String(readingTime))}
		</span>

		<!-- Title -->
		<h3
			class="mt-2 font-mono text-lg font-semibold text-foreground group-hover:text-foreground"
		>
			{title}
		</h3>

		<!-- Description -->
		<p class="mt-2 line-clamp-2 text-sm leading-relaxed text-muted-foreground">
			{description}
		</p>

		<!-- Separator -->
		<hr class="my-4 border-dashed border-border" />

		<!-- Tags -->
		<div class="flex flex-wrap gap-2">
			{tags.map((tag) => <SkillPill name={tag} showIcon={false} />)}
		</div>
	</a>
</article>
