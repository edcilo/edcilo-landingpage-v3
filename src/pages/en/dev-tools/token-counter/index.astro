---
import Layout from '../../../../layouts/Layout.astro';
import SectionHeading from '../../../../components/SectionHeading.astro';
import TokenCounterTool from '../../../../components/TokenCounterTool.astro';
import { DEFAULT_LOCALE } from '../../../../i18n/config';
import { useTranslations, getLocalizedPath } from '../../../../i18n/utils';

const locale = Astro.currentLocale ?? DEFAULT_LOCALE;
const t = useTranslations(locale);
---

<Layout
	title={`${t('devtools.tokens.title')} — edcilo`}
	description={t('devtools.tokens.subtitle')}
>
	<section class="py-16 sm:py-24" aria-labelledby="tokens-heading">
		<a
			href={getLocalizedPath('/dev-tools/', locale)}
			class="mb-8 inline-flex items-center gap-1 font-mono text-sm text-muted-foreground transition-colors hover:text-foreground"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				fill="none"
				viewBox="0 0 24 24"
				stroke-width="1.5"
				stroke="currentColor"
				class="size-4"
				aria-hidden="true"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"></path>
			</svg>
			{t('devtools.backToDevTools')}
		</a>

		<SectionHeading
			id="tokens-heading"
			title={t('devtools.tokens.title')}
			subtitle={t('devtools.tokens.subtitle')}
		/>

		<div class="mx-auto mb-10 max-w-3xl space-y-2">
			<p class="text-sm leading-relaxed text-muted-foreground">
				{t('devtools.tokens.description')}
			</p>
			<p class="font-mono text-sm text-muted-foreground">
				{t('devtools.tokens.example')}
			</p>
		</div>

		<TokenCounterTool
			modelLabel={t('devtools.tokens.model.label')}
			groupOpenaiLabel={t('devtools.tokens.model.group.openai')}
			groupClaudeLabel={t('devtools.tokens.model.group.claude')}
			gpt4oLabel={t('devtools.tokens.model.gpt4o')}
			gpt4Label={t('devtools.tokens.model.gpt4')}
			claudeLabel={t('devtools.tokens.model.claude')}
			inputLabel={t('devtools.tokens.input.label')}
			inputPlaceholder={t('devtools.tokens.input.placeholder')}
			tokensLabel={t('devtools.tokens.metric.tokens')}
			charsLabel={t('devtools.tokens.metric.chars')}
			wordsLabel={t('devtools.tokens.metric.words')}
			vizLabel={t('devtools.tokens.viz.label')}
			vizTruncated={t('devtools.tokens.viz.truncated')}
			encodingNotice={t('devtools.tokens.notice.encoding')}
			claudeNotice={t('devtools.tokens.notice.claudeEstimate')}
			loadingLabel={t('devtools.tokens.status.loading')}
		/>
	</section>
</Layout>
