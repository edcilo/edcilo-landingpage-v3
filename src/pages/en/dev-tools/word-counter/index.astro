---
import Layout from '../../../../layouts/Layout.astro';
import SectionHeading from '../../../../components/SectionHeading.astro';
import WordCounterTool from '../../../../components/WordCounterTool.astro';
import { DEFAULT_LOCALE } from '../../../../i18n/config';
import { useTranslations, getLocalizedPath } from '../../../../i18n/utils';

const locale = Astro.currentLocale ?? DEFAULT_LOCALE;
const t = useTranslations(locale);
---

<Layout
	title={`${t('devtools.wordcounter.title')} — edcilo`}
	description={t('devtools.wordcounter.subtitle')}
>
	<section class="py-16 sm:py-24" aria-labelledby="wordcounter-heading">
		<a
			href={getLocalizedPath('/dev-tools/', locale)}
			class="mb-8 inline-flex items-center gap-1 font-mono text-sm text-muted-foreground transition-colors hover:text-foreground"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				fill="none"
				viewBox="0 0 24 24"
				stroke-width="1.5"
				stroke="currentColor"
				class="size-4"
				aria-hidden="true"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"></path>
			</svg>
			{t('devtools.backToDevTools')}
		</a>

		<SectionHeading
			id="wordcounter-heading"
			title={t('devtools.wordcounter.title')}
			subtitle={t('devtools.wordcounter.subtitle')}
		/>

		<div class="mx-auto mb-10 max-w-3xl space-y-2">
			<p class="text-sm leading-relaxed text-muted-foreground">
				{t('devtools.wordcounter.description')}
			</p>
			<p class="font-mono text-sm text-muted-foreground">
				{t('devtools.wordcounter.example')}
			</p>
		</div>

		<WordCounterTool
			inputLabel={t('devtools.wordcounter.input.label')}
			inputPlaceholder={t('devtools.wordcounter.input.placeholder')}
			clearLabel={t('devtools.wordcounter.clear')}
			readingSpeedLabel={t('devtools.wordcounter.reading.label')}
			speakingSpeedLabel={t('devtools.wordcounter.speaking.label')}
			wpmUnit={t('devtools.wordcounter.wpm')}
			statWordsLabel={t('devtools.wordcounter.stat.words')}
			statCharsLabel={t('devtools.wordcounter.stat.chars')}
			statCharsNoSpacesLabel={t('devtools.wordcounter.stat.charsNoSpaces')}
			statLinesLabel={t('devtools.wordcounter.stat.lines')}
			timeReadingLabel={t('devtools.wordcounter.time.reading')}
			timeSpeakingLabel={t('devtools.wordcounter.time.speaking')}
			timeLessThanMin={t('devtools.wordcounter.time.lessThanMin')}
			timeMin={t('devtools.wordcounter.time.min')}
			timeEmpty={t('devtools.wordcounter.time.empty')}
		/>
	</section>
</Layout>
