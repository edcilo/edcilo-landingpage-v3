---
interface Props {
	originalLabel: string;
	originalPlaceholder: string;
	modifiedLabel: string;
	modifiedPlaceholder: string;
	compareLabel: string;
	copyLabel: string;
	copiedLabel: string;
	outputLabel: string;
	addedLabel: string;
	removedLabel: string;
	unchangedLabel: string;
	noDiffMessage: string;
	tooLargeMessage: string;
}

const {
	originalLabel,
	originalPlaceholder,
	modifiedLabel,
	modifiedPlaceholder,
	compareLabel,
	copyLabel,
	copiedLabel,
	outputLabel,
	addedLabel,
	removedLabel,
	unchangedLabel,
	noDiffMessage,
	tooLargeMessage,
} = Astro.props;

const textareaClass =
	'w-full resize-y rounded-lg border border-border bg-muted/50 px-4 py-3 font-mono text-sm text-foreground placeholder:text-muted-foreground transition-colors duration-200 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20';
const labelClass = 'mb-2 block font-mono text-sm font-medium text-foreground';
---

<div
	data-diff-tool
	data-copied-label={copiedLabel}
	data-added-label={addedLabel}
	data-removed-label={removedLabel}
	data-unchanged-label={unchangedLabel}
	data-nodiff-message={noDiffMessage}
	data-toolarge-message={tooLargeMessage}
	class="mx-auto max-w-3xl space-y-6"
>
	<!-- Inputs -->
	<div class="grid grid-cols-1 gap-4 md:grid-cols-2">
		<div>
			<label for="diff-original" class={labelClass}>{originalLabel}</label>
			<textarea
				id="diff-original"
				data-diff-original
				rows="10"
				spellcheck="false"
				placeholder={originalPlaceholder}
				class={textareaClass}></textarea>
		</div>
		<div>
			<label for="diff-modified" class={labelClass}>{modifiedLabel}</label>
			<textarea
				id="diff-modified"
				data-diff-modified
				rows="10"
				spellcheck="false"
				placeholder={modifiedPlaceholder}
				class={textareaClass}></textarea>
		</div>
	</div>

	<!-- Actions -->
	<div class="flex flex-wrap items-center justify-center gap-3">
		<button
			type="button"
			data-diff-compare
			class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-2.5 font-mono text-sm font-medium text-primary-foreground transition-colors duration-200 hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:ring-offset-2 focus:ring-offset-background"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				fill="none"
				viewBox="0 0 24 24"
				stroke-width="1.5"
				stroke="currentColor"
				class="size-5"
				aria-hidden="true"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"
				></path>
			</svg>
			{compareLabel}
		</button>

		<button
			type="button"
			data-diff-copy
			disabled
			class="inline-flex items-center gap-2 rounded-lg border border-border bg-muted px-6 py-2.5 font-mono text-sm font-medium text-foreground transition-colors duration-200 hover:border-primary/40 hover:bg-primary/10 hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:ring-offset-2 focus:ring-offset-background disabled:cursor-not-allowed disabled:opacity-50 disabled:hover:border-border disabled:hover:bg-muted disabled:hover:text-foreground"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				fill="none"
				viewBox="0 0 24 24"
				stroke-width="1.5"
				stroke="currentColor"
				class="size-5"
				aria-hidden="true"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184"
				></path>
			</svg>
			<span data-diff-copy-label>{copyLabel}</span>
		</button>
	</div>

	<!-- Summary -->
	<p
		data-diff-summary
		aria-live="polite"
		class="hidden text-center font-mono text-sm text-muted-foreground tabular-nums"
	>
	</p>

	<!-- Output -->
	<div data-diff-output-wrapper class="hidden">
		<span class={labelClass}>{outputLabel}</span>
		<div
			data-diff-output
			aria-live="polite"
			class="overflow-x-auto rounded-lg border border-border bg-muted/30 py-2 font-mono text-sm leading-relaxed"
		>
		</div>
	</div>
</div>

<script>
	type DiffType = 'equal' | 'add' | 'remove';
	interface DiffOp {
		type: DiffType;
		line: string;
	}

	// Maximum DP cells (rows * cols) before we bail out to avoid freezing the tab.
	const MAX_CELLS = 4_000_000;

	function splitLines(text: string): string[] {
		return text.split(/\r?\n/);
	}

	function lcsDiff(a: string[], b: string[]): DiffOp[] {
		const n = a.length;
		const m = b.length;
		// DP table of LCS lengths.
		const dp: number[][] = Array.from({ length: n + 1 }, () =>
			new Array<number>(m + 1).fill(0),
		);
		for (let i = n - 1; i >= 0; i--) {
			for (let j = m - 1; j >= 0; j--) {
				dp[i][j] =
					a[i] === b[j]
						? dp[i + 1][j + 1] + 1
						: Math.max(dp[i + 1][j], dp[i][j + 1]);
			}
		}
		// Backtrack to build the ordered diff.
		const ops: DiffOp[] = [];
		let i = 0;
		let j = 0;
		while (i < n && j < m) {
			if (a[i] === b[j]) {
				ops.push({ type: 'equal', line: a[i] });
				i++;
				j++;
			} else if (dp[i + 1][j] >= dp[i][j + 1]) {
				ops.push({ type: 'remove', line: a[i] });
				i++;
			} else {
				ops.push({ type: 'add', line: b[j] });
				j++;
			}
		}
		while (i < n) {
			ops.push({ type: 'remove', line: a[i] });
			i++;
		}
		while (j < m) {
			ops.push({ type: 'add', line: b[j] });
			j++;
		}
		return ops;
	}

	function setupDiffTool(): void {
		const containers =
			document.querySelectorAll<HTMLElement>('[data-diff-tool]');
		containers.forEach((container) => {
			if (container.hasAttribute('data-diff-initialized')) return;
			container.setAttribute('data-diff-initialized', '');

			const originalEl = container.querySelector<HTMLTextAreaElement>(
				'[data-diff-original]',
			);
			const modifiedEl = container.querySelector<HTMLTextAreaElement>(
				'[data-diff-modified]',
			);
			const compareBtn = container.querySelector<HTMLButtonElement>(
				'[data-diff-compare]',
			);
			const copyBtn =
				container.querySelector<HTMLButtonElement>('[data-diff-copy]');
			const copyLabelEl = container.querySelector<HTMLElement>(
				'[data-diff-copy-label]',
			);
			const summaryEl = container.querySelector<HTMLElement>(
				'[data-diff-summary]',
			);
			const outputWrapper = container.querySelector<HTMLElement>(
				'[data-diff-output-wrapper]',
			);
			const outputEl =
				container.querySelector<HTMLElement>('[data-diff-output]');

			if (
				!originalEl ||
				!modifiedEl ||
				!compareBtn ||
				!copyBtn ||
				!summaryEl ||
				!outputWrapper ||
				!outputEl
			) {
				return;
			}

			const copyText = copyLabelEl?.textContent ?? '';
			const copiedText = container.getAttribute('data-copied-label') ?? '';
			const addedLabel = container.getAttribute('data-added-label') ?? '';
			const removedLabel = container.getAttribute('data-removed-label') ?? '';
			const unchangedLabel =
				container.getAttribute('data-unchanged-label') ?? '';
			const noDiffMessage = container.getAttribute('data-nodiff-message') ?? '';
			const tooLargeMessage =
				container.getAttribute('data-toolarge-message') ?? '';
			let copyTimeout: ReturnType<typeof setTimeout> | undefined;
			let lastOps: DiffOp[] = [];

			function showMessage(message: string): void {
				summaryEl!.classList.remove('hidden');
				summaryEl!.textContent = message;
				outputWrapper!.classList.add('hidden');
				outputEl!.replaceChildren();
				copyBtn!.disabled = true;
				lastOps = [];
			}

			function renderDiff(ops: DiffOp[]): void {
				outputEl!.replaceChildren();
				const config: Record<DiffType, { prefix: string; cls: string }> = {
					equal: { prefix: ' ', cls: 'text-muted-foreground' },
					add: {
						prefix: '+',
						cls: 'bg-green-500/10 text-green-600 dark:text-green-400',
					},
					remove: {
						prefix: '-',
						cls: 'bg-red-500/10 text-red-600 dark:text-red-400',
					},
				};
				const frag = document.createDocumentFragment();
				ops.forEach((op) => {
					const row = document.createElement('div');
					row.className = `whitespace-pre-wrap break-words px-4 ${config[op.type].cls}`;
					// textContent avoids any HTML injection from user input.
					row.textContent = `${config[op.type].prefix} ${op.line}`;
					frag.appendChild(row);
				});
				outputEl!.appendChild(frag);
				outputWrapper!.classList.remove('hidden');
			}

			function compare(): void {
				const a = splitLines(originalEl!.value);
				const b = splitLines(modifiedEl!.value);

				if (originalEl!.value === modifiedEl!.value) {
					showMessage(noDiffMessage);
					return;
				}
				if (a.length * b.length > MAX_CELLS) {
					showMessage(tooLargeMessage);
					return;
				}

				const ops = lcsDiff(a, b);
				lastOps = ops;
				let added = 0;
				let removed = 0;
				let unchanged = 0;
				ops.forEach((op) => {
					if (op.type === 'add') added++;
					else if (op.type === 'remove') removed++;
					else unchanged++;
				});

				summaryEl!.classList.remove('hidden');
				summaryEl!.textContent = `+${added} ${addedLabel} · −${removed} ${removedLabel} · =${unchanged} ${unchangedLabel}`;
				renderDiff(ops);
				copyBtn!.disabled = ops.length === 0;
			}

			function toPlainText(ops: DiffOp[]): string {
				return ops
					.map((op) => {
						const prefix =
							op.type === 'add' ? '+' : op.type === 'remove' ? '-' : ' ';
						return `${prefix} ${op.line}`;
					})
					.join('\n');
			}

			compareBtn.addEventListener('click', compare);

			copyBtn.addEventListener('click', async () => {
				if (!lastOps.length) return;
				try {
					await navigator.clipboard.writeText(toPlainText(lastOps));
					if (copyLabelEl) {
						copyLabelEl.textContent = copiedText;
						if (copyTimeout) clearTimeout(copyTimeout);
						copyTimeout = setTimeout(() => {
							copyLabelEl.textContent = copyText;
						}, 2000);
					}
				} catch {
					/* Clipboard unavailable: silently ignore. */
				}
			});
		});
	}

	setupDiffTool();
	document.addEventListener('astro:page-load', setupDiffTool);
</script>
